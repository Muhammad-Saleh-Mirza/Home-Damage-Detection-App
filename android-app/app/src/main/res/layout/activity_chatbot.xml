<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:theme="@style/Theme.FixUp.Toolbar"
            app:title="🤖 FixUp Assistant"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/colorSurface">

        <!-- Messages list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <!-- Quick reply chips -->
        <HorizontalScrollView
            android:id="@+id/scrollChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEstimate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimate repair cost"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/colorAccent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFairPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Is my price fair?"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/colorAccent" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What service do I need?"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    app:chipStrokeColor="@color/colorAccent"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/colorAccent" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:background="@color/colorSurface"
            android:elevation="4dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask me anything…"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSend"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                app:icon="@drawable/ic_send"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="24dp" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
